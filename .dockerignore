# Build outputs. The Synology runtime image copies only the local release
# artifacts below; everything else under build/ stays out of the context.
build/
!build/
build/*
!build/ext/
build/ext/*
!build/ext/server/
build/ext/server/*
!build/ext/server/mcp-ext-server
!build/plugins/
build/plugins/*
!build/plugins/libsynology_tools.so
build-*/

# VCS / IDE / OS
.git/
.gitignore
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Python venvs and caches (uv rebuilds inside the image)
**/.venv/
**/__pycache__/
*.pyc

# Docs / specs / plans (not needed in the image)
docs/
*.md
!ext/server/plugins/synology/backend/README.md

# Build dirs from other examples we don't ship in this image
examples/*/build/
